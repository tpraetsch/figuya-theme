{
  "name": "figuya-dark",
  "type": "dark",
  "colors": {
    "editor.background": "#251d1b",
    "editor.foreground": "#f5ece0",
    "editorCursor.foreground": "#f76707",
    "editor.lineHighlightBackground": "#50403d",
    "editor.selectionBackground": "#50403d",
    "editorLineNumber.foreground": "#ad9890",
    "editorLineNumber.activeForeground": "#f76707",
    "editorIndentGuide.background1": "#3b2f31",
    "editorWhitespace.foreground": "#3b2f31",
    "editorWidget.background": "#2e2422",
    "editorHoverWidget.background": "#2e2422",
    "editorSuggestWidget.background": "#2e2422",
    "editorSuggestWidget.selectedBackground": "#50403d",
    "editorError.foreground": "#f36868",
    "editorWarning.foreground": "#f59f00",
    "editorInfo.foreground": "#4c9adf",
    "sideBar.background": "#2e2422",
    "sideBar.foreground": "#f5ece0",
    "activityBar.background": "#2e2422",
    "activityBar.foreground": "#f76707",
    "statusBar.background": "#3b2f31",
    "statusBar.foreground": "#f5ece0",
    "statusBar.noFolderBackground": "#3b2f31",
    "statusBar.debuggingBackground": "#f76707",
    "titleBar.activeBackground": "#2e2422",
    "titleBar.activeForeground": "#f5ece0",
    "tab.activeBackground": "#251d1b",
    "tab.inactiveBackground": "#3b2f31",
    "tab.activeForeground": "#f5ece0",
    "tab.inactiveForeground": "#ad9890",
    "tab.activeBorderTop": "#f76707",
    "panel.background": "#251d1b",
    "terminal.background": "#251d1b",
    "terminal.foreground": "#f5ece0",
    "focusBorder": "#f76707",
    "button.background": "#f76707",
    "button.foreground": "#2d2220",
    "list.activeSelectionBackground": "#50403d",
    "list.hoverBackground": "#3b2f31",
    "badge.background": "#f76707",
    "badge.foreground": "#2d2220",
    "terminal.ansiBlack": "#3b2f31",
    "terminal.ansiBrightBlack": "#ad9890",
    "terminal.ansiRed": "#f36868",
    "terminal.ansiBrightRed": "#f36868",
    "terminal.ansiGreen": "#45a857",
    "terminal.ansiBrightGreen": "#45a857",
    "terminal.ansiYellow": "#f59f00",
    "terminal.ansiBrightYellow": "#f59f00",
    "terminal.ansiBlue": "#4c9adf",
    "terminal.ansiBrightBlue": "#4c9adf",
    "terminal.ansiMagenta": "#e27098",
    "terminal.ansiBrightMagenta": "#e27098",
    "terminal.ansiCyan": "#13a97c",
    "terminal.ansiBrightCyan": "#13a97c",
    "terminal.ansiWhite": "#d1c2b8",
    "terminal.ansiBrightWhite": "#f5ece0"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#ad9890",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#45a857"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#e27098"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#e27098"
      }
    },
    {
      "scope": "constant.character, constant.other",
      "settings": {
        "foreground": "#e27098"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#f5ece0"
      }
    },
    {
      "scope": "variable.language, variable.other.constant",
      "settings": {
        "foreground": "#f76a0b"
      }
    },
    {
      "scope": "keyword, storage.type, storage.modifier",
      "settings": {
        "foreground": "#9f82f6"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#f76a0b"
      }
    },
    {
      "scope": "entity.name.function, support.function",
      "settings": {
        "foreground": "#4c9adf"
      }
    },
    {
      "scope": "entity.name.type, support.type, entity.name.class",
      "settings": {
        "foreground": "#f59f00"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#9f82f6"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#4c9adf"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#f5ece0"
      }
    },
    {
      "scope": "punctuation, meta.brace",
      "settings": {
        "foreground": "#ad9890"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "foreground": "#f76a0b",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "foreground": "#f5ece0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "foreground": "#f5ece0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.inline.raw, markup.fenced_code",
      "settings": {
        "foreground": "#45a857"
      }
    },
    {
      "scope": "markup.underline.link",
      "settings": {
        "foreground": "#4c9adf",
        "fontStyle": "underline"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#f36868"
      }
    }
  ]
}
